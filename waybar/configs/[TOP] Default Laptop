{
  "include": [
    "$HOME/.config/waybar/Modules",
    "$HOME/.config/waybar/ModulesWorkspaces",
    "$HOME/.config/waybar/ModulesCustom",
    "$HOME/.config/waybar/ModulesGroups",
    "$HOME/.config/waybar/UserModules"
  ],
  "layer": "top",
  "margin-top": 6,
  "margin-left": 8,
  "margin-right": 8,
  "margin-bottom": 2,
  "height": 34,
  "modules-left": ["custom/launcher", "hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["network", "backlight", "cpu", "memory", "hyprland/language", "wireplumber", "battery", "custom/power"],
  
  "wireplumber": {
    "tooltip": false,
    "scroll-step": 5,
    "format": "<span color='#89b4fa'>{icon}</span> {volume}%",
    "format-muted": "<span color='#89b4fa'>󰝟</span> {volume}%",
    "on-click": "kitty -- alsamixer -V all",
    "format-icons": {
      "default": ["", "", ""]
    }
  },

  "network": {
    "tooltip": false,
    "format-wifi": "<span color='#74c7ec'> </span> {essid}",
    "format-ethernet": "<span color='#74c7ec'>󰈀</span>",
    "format-disconnected": "<span color='#74c7ec'>󰤮</span>",
    "on-click": "kitty -- nmtui"
  },

  "backlight": {
    "tooltip": false,
    "format": "<span color='#f9e2af'></span> {percent}%",
    "interval": 1,
    "on-scroll-up": "light -A 5",
    "on-scroll-down": "light -U 5"
  },

  "battery": {
    "states": {
      "full": 100,
      "good": 95,
      "decent": 50,
      "warning": 30,
      "critical": 20
    },
    "format": "<span color='#a6e3a1'>{icon}</span> {capacity}%",
    "format-time": "{H} h {M} min",
    "format-alt": "<span color='#a6e3a1'>{icon}</span> {time}",
    "format-icons": ["", "", "", "", ""]
  },

  "clock": {
    "format": "<span color='#cba6f7'></span> {:%a, %d %b %H:%M:%S}",
    "format-alt": "<span color='#cba6f7'></span> {:%d-%m-%y %H:%M:%S}",
    "interval": 1
  },

  "cpu": {
    "interval": 15,
    "format": "<span color='#cba6f7'></span> {}%",
    "max-length": 10,
    "on-click": "kitty -- btop"
  },

  "memory": {
    "interval": 30,
    "format": "<span color='#a6c9f7'></span> {}%",
    "max-length": 10
  },

  "custom/media": {
    "interval": 30,
    "format": "<span color='#b4befe'>{icon}</span> {}",
    "return-type": "json",
    "max-length": 20,
    "format-icons": {
      "spotify": "",
      "default": ""
    },
    "escape": true,
    "exec": "$HOME/.config/system_scripts/mediaplayer.py 2> /dev/null",
    "on-click": "playerctl play-pause"
  },

  "custom/launcher": {
    "format": "<span color='#89b4fa'> </span>",
    "on-click": "sh ~/.config/rofi/launchers/type-2/launcher.sh",
    "on-click-right": "killall rofi"
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "default": "",
      "empty": "",
      "focused": "",
      "active": ""
    },
    "on-click": "activate",
    "sort-by-number": true,
    "disable-scroll": true
  }
}
